# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# Local:       postgresql://propellex:propellex@localhost:5432/propellex
# Neon (prod): postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://propellex:propellex@localhost:5432/propellex

# ── Redis ───────────────────────────────────────────────────────────────────────
# Local:        redis://localhost:6379
# Upstash (prod): rediss://default:xxx@us1-xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# e.g. production: https://propellex.vercel.app,https://your-domain.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Email (Resend) ──────────────────────────────────────────────────────────────
# Get your free API key at https://resend.com → API Keys
# Free tier: 3,000 emails/month, 100/day
# Without a key, OTPs fall back to console.log (local dev only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# From address — use onboarding@resend.dev for testing; set your domain in prod
# e.g. Propellex <noreply@yourdomain.com>
EMAIL_FROM=Propellex <onboarding@resend.dev>

# ── AI Service ──────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── File Storage ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Frontend (Vite) ─────────────────────────────────────────────────────────────
# Local:  http://localhost:3001
# Prod:   https://propellex-backend.onrender.com  (your Render backend URL)
VITE_API_URL=http://localhost:3001
