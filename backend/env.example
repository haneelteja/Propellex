# Server Configuration
PORT=5000
NODE_ENV=development

# Database - MongoDB or Azure Cosmos DB
MONGODB_URI=mongodb://localhost:27017/propellex
# For Azure Cosmos DB, use:
# AZURE_COSMOS_DB_CONNECTION_STRING=your-cosmos-db-connection-string

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Azure Services (Optional - for production)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=propellex-rg
AZURE_LOCATION=centralindia

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# Azure Redis Cache
AZURE_REDIS_HOST=
AZURE_REDIS_PORT=6380
AZURE_REDIS_KEY=

# Azure Key Vault
AZURE_KEY_VAULT_NAME=
AZURE_KEY_VAULT_SECRET=

# Azure Application Insights
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING=

# CORS
CORS_ORIGIN=http://localhost:3000

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
