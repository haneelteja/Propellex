# ── WhatsApp Channel — 360Messenger config ──────────────────────────────────
# Copy this file to .env and fill in your values

# Your 360Messenger API key (from https://360messenger.com → API Keys)
MESSENGER_API_KEY=your_api_key_here

# The WhatsApp group ID to monitor and reply in
# Get it by sending a message to the group and checking receivedMessages API:
#   curl https://api.360messenger.com/v2/message/receivedMessages \
#        -H "Authorization: Bearer YOUR_KEY"
# Look for the "groupId" field in the response (e.g. "120363344915882")
# Do NOT include @g.us — just the numeric part
WHATSAPP_GROUP_ID=120363344915882

# Comma-separated phone numbers allowed to trigger Claude (no + prefix, no spaces)
# Anyone NOT in this list will be silently dropped
# Use your own phone number(s) and trusted team members only
ALLOWED_SENDERS=919876543210,447488888888

# How often to poll 360Messenger for new messages (milliseconds, default 5000)
POLL_INTERVAL_MS=5000
